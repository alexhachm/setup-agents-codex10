#!/usr/bin/env bash
# codex10 — CLI wrapper for the codex10 multi-agent coordinator
#
# Dispatches instruction-patch pipeline commands to patch-pipeline.js;
# all other commands are forwarded to the mac10 coordinator binary.
#
# Pipeline hook: after a successful `distill`, the content is scanned for
# candidate instruction-patch signals and any findings are logged to stderr
# so master-2 can decide whether to call propose-patch.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MAC10_BIN="/mnt/c/Users/Owner/Desktop/setup-agents-codex10/coordinator/bin/mac10"
PATCH_PIPELINE="$SCRIPT_DIR/patch-pipeline.js"

if [ ! -f "$MAC10_BIN" ]; then
  echo "ERROR: mac10 CLI not found at $MAC10_BIN" >&2
  echo "  Has the setup-agents repo moved? Re-run setup.sh to fix." >&2
  exit 1
fi

CMD="${1:-}"

case "$CMD" in

  # ── Instruction-patch governance pipeline ──────────────────────────────────
  #
  # These commands are handled locally (no coordinator connection needed).
  #
  propose-patch | observe-patch | approve-patch | apply-patch | \
  reject-patch  | list-patches  | scan-distills)
    exec node "$PATCH_PIPELINE" "$@"
    ;;

  # ── Distill hook ────────────────────────────────────────────────────────────
  #
  # Passes the distill command through to mac10, then runs scan-distills on the
  # content to surface any candidate patch proposals to stderr.
  #
  distill)
    export MAC10_NAMESPACE="codex10"
    node "$MAC10_BIN" "$@"
    DISTILL_EXIT=$?

    # Only scan if distill succeeded and content argument is present
    if [ $DISTILL_EXIT -eq 0 ] && [ $# -ge 4 ]; then
      DOMAIN="$3"
      CONTENT="$4"
      CANDIDATES=$(node "$PATCH_PIPELINE" scan-distills "$DOMAIN" "$CONTENT" 2>/dev/null)
      if [ -n "$CANDIDATES" ] && [ "$CANDIDATES" != "[]" ]; then
        echo "[patch-pipeline] scan-distills found candidate(s) for domain '$DOMAIN':" >&2
        echo "$CANDIDATES" >&2
        echo "[patch-pipeline] Use 'codex10 propose-patch ...' to stage a patch proposal." >&2
      fi
    fi

    exit $DISTILL_EXIT
    ;;

  # ── All other commands → mac10 coordinator ────────────────────────────────
  *)
    export MAC10_NAMESPACE="codex10"
    exec node "$MAC10_BIN" "$@"
    ;;

esac
