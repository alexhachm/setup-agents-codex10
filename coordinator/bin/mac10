#!/usr/bin/env node
'use strict';

const net = require('net');
const path = require('path');
const fs = require('fs');
const { execFileSync } = require('child_process');
const { coordinatorAgeMs } = require('../src/db');
const providerOutput = require('../src/provider-output');
const NAMESPACE = process.env.MAC10_NAMESPACE || 'mac10';
const STRICT_NAMESPACE = Boolean(process.env.MAC10_NAMESPACE) && process.env.MAC10_NAMESPACE !== 'mac10';
const BRANCH_RE = /^[a-zA-Z0-9._\/-]+$/;
const PR_URL_RE = /^https:\/\/github\.com\/[a-zA-Z0-9._-]+\/[a-zA-Z0-9._-]+\/pull\/\d+$/;
const PR_NUMBER_RE = /^#?(\d+)$/;
const PR_REFERENCE_RE = /^(pull request|pull|pr)\s*#?(\d+)$/i;
const WORKER_BRANCH_RE = /^agent-\d+$/;
const INBOX_RECIPIENT_ALIASES = Object.freeze({
  'master-2': 'architect',
  'master-3': 'allocator',
});

function completionStatusLabel(completion) {
  const total = Number(completion && completion.total) || 0;
  const completed = Number(completion && completion.completed) || 0;
  const failed = Number(completion && completion.failed) || 0;
  const requestStatus = completion && typeof completion.request_status === 'string'
    ? completion.request_status
    : '';
  if (total === 0 && requestStatus === 'completed') return 'COMPLETED (NO TASKS)';
  if (total === 0 && requestStatus === 'failed') return 'ALL FAILED (NO TASKS)';
  if (total > 0 && completed === total && failed === 0) return 'ALL DONE';
  if (total > 0 && failed === total && completed === 0) return 'ALL FAILED';
  if (completed > 0 && failed > 0) return 'MIXED (HAS FAILURES)';
  return '';
}

function namespacedCandidates(baseName) {
  if (NAMESPACE === 'mac10') return [baseName];
  const dot = baseName.indexOf('.');
  const namespaced = dot === -1 ? `${NAMESPACE}.${baseName}` : `${NAMESPACE}${baseName.slice(dot)}`;
  return STRICT_NAMESPACE ? [namespaced] : [namespaced, baseName];
}

// Connection target: either a socket path (string) or TCP config ({host, port})
// Priority: Unix socket (fastest, native) > TCP bridge > Windows named pipe
function findConnectionTarget() {
  if (process.env.MAC10_SOCKET) return process.env.MAC10_SOCKET;

  // Direct TCP override (used by workers inside microVMs/containers)
  if (process.env.MAC10_CLI_HOST && process.env.MAC10_CLI_PORT) {
    const port = parseInt(process.env.MAC10_CLI_PORT, 10);
    if (port > 0) return { host: process.env.MAC10_CLI_HOST, port };
  }

  let dir = process.cwd();
  while (dir !== path.dirname(dir)) {
    const stateDir = path.join(dir, '.claude', 'state');

    // 1. Unix socket path redirect (WSL2/NTFS workaround — most reliable on WSL)
    for (const name of namespacedCandidates('mac10.sock.path')) {
      const sockPathFile = path.join(stateDir, name);
      if (fs.existsSync(sockPathFile)) {
        const sockPath = fs.readFileSync(sockPathFile, 'utf8').trim();
        // Verify the socket actually exists (avoid stale references)
        try { if (fs.statSync(sockPath).isSocket()) return sockPath; } catch {}
      }
    }

    // 2. Unix socket file directly
    for (const name of namespacedCandidates('mac10.sock')) {
      const sock = path.join(stateDir, name);
      try { if (fs.existsSync(sock) && fs.statSync(sock).isSocket()) return sock; } catch {}
    }

    // 3. TCP bridge (cross-environment: Git Bash ↔ WSL)
    for (const name of namespacedCandidates('mac10.tcp.port')) {
      const tcpFile = path.join(stateDir, name);
      if (fs.existsSync(tcpFile)) {
        const port = parseInt(fs.readFileSync(tcpFile, 'utf8').trim(), 10);
        if (port > 0) return { host: process.env.MAC10_CLI_HOST || '127.0.0.1', port };
      }
    }

    // 4. Windows named pipe (last — often stale when coordinator moves to WSL)
    for (const name of namespacedCandidates('mac10.pipe')) {
      const pipeFile = path.join(stateDir, name);
      if (fs.existsSync(pipeFile)) {
        return fs.readFileSync(pipeFile, 'utf8').trim();
      }
    }

    dir = path.dirname(dir);
  }
  console.error('Error: mac10 coordinator not running (no socket found)');
  console.error('Run "mac10 start" from the project root first.');
  process.exit(1);
}

function getTransportTimeoutMs(command, args) {
  if (command === 'inbox-block') {
    const requestedTimeout = Number(args && args.timeout);
    // Match caller intent for blocking inbox timeout and add a small buffer
    // so the server can send its final empty response at deadline.
    if (Number.isFinite(requestedTimeout) && requestedTimeout > 0) {
      return requestedTimeout + 2000;
    }
    return 302000;
  }
  return 30000;
}

function normalizeInboxRecipient(recipient) {
  if (typeof recipient !== 'string') return recipient;
  return INBOX_RECIPIENT_ALIASES[recipient] || recipient;
}

function send(target, command, args) {
  return new Promise((resolve, reject) => {
    let settled = false;
    const settle = (fn, val) => { if (!settled) { settled = true; fn(val); } };

    const onConnect = () => {
      conn.end(JSON.stringify({ command, args }) + '\n');
    };
    // Connect via TCP ({host, port}) or Unix socket/named pipe (string)
    const conn = typeof target === 'object'
      ? net.createConnection(target.port, target.host, onConnect)
      : net.createConnection(target, onConnect);

    let data = '';
    conn.on('data', (chunk) => {
      data += chunk.toString();
      const idx = data.indexOf('\n');
      if (idx >= 0) {
        try {
          settle(resolve, JSON.parse(data.slice(0, idx)));
        } catch (e) {
          settle(reject, new Error('Invalid response from coordinator'));
        }
        if (!conn.destroyed) conn.end();
      }
    });
    conn.on('error', (e) => {
      if (e.code === 'ENOENT' || e.code === 'ECONNREFUSED') {
        settle(reject, new Error('Coordinator not running. Start with: mac10 start'));
      } else {
        settle(reject, e);
      }
    });
    conn.on('close', () => {
      // Connection closed without a complete response
      settle(reject, new Error('Connection closed before receiving a complete response'));
    });
    const timeout = getTransportTimeoutMs(command, args);
    conn.setTimeout(timeout, () => {
      conn.end();
      settle(reject, new Error(`Transport timeout for command "${command}" after ${timeout}ms`));
    });
  });
}

function findConnectionTargetForProject(projectDir) {
  // Walk up from projectDir to find the coordinator socket.
  // This handles worktrees (e.g. .worktrees/wt-1/) where the coordinator
  // socket lives in the parent project's .claude/state/ directory.
  let dir = path.resolve(projectDir);
  while (dir !== path.dirname(dir)) {
    const stateDir = path.join(dir, '.claude', 'state');

    for (const name of namespacedCandidates('mac10.sock.path')) {
      const sockPathFile = path.join(stateDir, name);
      if (fs.existsSync(sockPathFile)) {
        const sockPath = fs.readFileSync(sockPathFile, 'utf8').trim();
        try { if (fs.statSync(sockPath).isSocket()) return sockPath; } catch {}
      }
    }

    for (const name of namespacedCandidates('mac10.sock')) {
      const sock = path.join(stateDir, name);
      try { if (fs.existsSync(sock) && fs.statSync(sock).isSocket()) return sock; } catch {}
    }

    for (const name of namespacedCandidates('mac10.tcp.port')) {
      const tcpFile = path.join(stateDir, name);
      if (fs.existsSync(tcpFile)) {
        const port = parseInt(fs.readFileSync(tcpFile, 'utf8').trim(), 10);
        if (port > 0) return { host: '127.0.0.1', port };
      }
    }

    for (const name of namespacedCandidates('mac10.pipe')) {
      const pipeFile = path.join(stateDir, name);
      if (fs.existsSync(pipeFile)) {
        return fs.readFileSync(pipeFile, 'utf8').trim();
      }
    }

    dir = path.dirname(dir);
  }

  console.error(`Error: mac10 coordinator not running for project: ${projectDir}`);
  process.exit(1);
}

function getCandidateTargetsForProject(projectDir) {
  // Walk up from projectDir to find candidates (handles worktrees)
  const targets = [];
  let dir = path.resolve(projectDir);
  while (dir !== path.dirname(dir)) {
    const stateDir = path.join(dir, '.claude', 'state');

    for (const name of namespacedCandidates('mac10.sock.path')) {
      const sockPathFile = path.join(stateDir, name);
      if (!fs.existsSync(sockPathFile)) continue;
      const sockPath = fs.readFileSync(sockPathFile, 'utf8').trim();
      if (sockPath) targets.push({ type: 'socket-path-file', file: sockPathFile, target: sockPath });
    }

    for (const name of namespacedCandidates('mac10.sock')) {
      const sock = path.join(stateDir, name);
      if (fs.existsSync(sock)) targets.push({ type: 'socket-file', target: sock });
    }

    for (const name of namespacedCandidates('mac10.tcp.port')) {
      const tcpFile = path.join(stateDir, name);
      if (!fs.existsSync(tcpFile)) continue;
      const port = parseInt(fs.readFileSync(tcpFile, 'utf8').trim(), 10);
      if (port > 0) targets.push({ type: 'tcp-file', file: tcpFile, target: { host: '127.0.0.1', port } });
    }

    for (const name of namespacedCandidates('mac10.pipe')) {
      const pipeFile = path.join(stateDir, name);
      if (!fs.existsSync(pipeFile)) continue;
      const pipePath = fs.readFileSync(pipeFile, 'utf8').trim();
      if (pipePath) targets.push({ type: 'pipe-file', file: pipeFile, target: pipePath });
    }

    if (targets.length > 0) break;
    dir = path.dirname(dir);
  }

  return targets;
}

function getPidFilePath(projectDir) {
  const base = NAMESPACE === 'mac10' ? 'mac10.pid' : `${NAMESPACE}.pid`;
  return path.join(projectDir, '.claude', 'state', base);
}

function findProjectRoot(startDir = process.cwd()) {
  let dir = path.resolve(startDir);
  while (dir !== path.dirname(dir)) {
    if (fs.existsSync(path.join(dir, '.claude', 'state'))) {
      return dir;
    }
    dir = path.dirname(dir);
  }
  return path.resolve(startDir);
}

function cleanupNamespaceEndpoints(projectDir) {
  const stateDir = path.join(projectDir, '.claude', 'state');
  const pointerNames = ['mac10.sock.path', 'mac10.sock', 'mac10.tcp.port', 'mac10.pipe'];
  for (const baseName of pointerNames) {
    for (const name of namespacedCandidates(baseName)) {
      const pointer = path.join(stateDir, name);
      if (!fs.existsSync(pointer)) continue;
      if (baseName === 'mac10.sock.path') {
        try {
          const sockPath = fs.readFileSync(pointer, 'utf8').trim();
          if (sockPath) fs.unlinkSync(sockPath);
        } catch {}
      }
      try { fs.unlinkSync(pointer); } catch {}
    }
  }
}

function isPidAlive(pid) {
  if (!Number.isInteger(pid) || pid <= 0) return false;
  try {
    process.kill(pid, 0);
    return true;
  } catch {
    return false;
  }
}

function formatDetails(details) {
  if (details === undefined || details === null) return '';
  if (typeof details === 'string') return details;
  try { return JSON.stringify(details); } catch { return String(details); }
}

function formatMergeAge(createdAt, includeAgo = false) {
  if (typeof coordinatorAgeMs !== 'function') return '';
  let ageMs;
  try {
    ageMs = coordinatorAgeMs(createdAt);
  } catch {
    return '';
  }
  if (!Number.isFinite(ageMs)) return '';
  const suffix = includeAgo ? ' ago' : '';
  return `${Math.round(ageMs / 60000)}m${suffix}`;
}

function sanitizeSingleLineCell(value) {
  if (value === undefined || value === null) return '';
  return String(value).replace(/[\u0000-\u001f\u007f-\u009f]/g, ' ');
}

function formatRequestSummaryDescription(description) {
  return sanitizeSingleLineCell(description).slice(0, 60);
}

function normalizeLoopRequestsPayload(payload) {
  if (!payload || typeof payload !== 'object') {
    return { ok: false, error: 'Invalid loop-requests response', requests: [] };
  }
  const requests = Array.isArray(payload.requests) ? payload.requests : [];
  return { ...payload, requests };
}

function printLoopRequestsRows(requests) {
  if (requests.length === 0) {
    console.log('No requests for this loop.');
    return;
  }
  for (const r of requests) {
    console.log(`  ${r.id} [${r.status}] ${r.tier ? `T${r.tier}` : '  '} ${formatRequestSummaryDescription(r.description)}`);
  }
}

function normalizeSourceRevision(data) {
  const sourceRevision = data && data.source_revision && typeof data.source_revision === 'object'
    ? data.source_revision
    : {};
  const normalizeCommit = (value) => {
    if (value === undefined || value === null) return null;
    const trimmed = String(value).trim();
    return trimmed || null;
  };
  const normalizeCount = (value) => {
    if (value === undefined || value === null || value === '') return null;
    const parsed = Number.parseInt(String(value), 10);
    return Number.isInteger(parsed) ? parsed : null;
  };
  return {
    current_branch: normalizeCommit(sourceRevision.current_branch),
    head_commit: normalizeCommit(sourceRevision.head_commit),
    origin_main_commit: normalizeCommit(sourceRevision.origin_main_commit),
    ahead_count: normalizeCount(sourceRevision.ahead_count),
    behind_count: normalizeCount(sourceRevision.behind_count),
    dirty_worktree: typeof sourceRevision.dirty_worktree === 'boolean' ? sourceRevision.dirty_worktree : null,
  };
}

function summarizeCommit(commit) {
  if (!commit) return 'unknown';
  return commit.slice(0, 12);
}

function hasRevisionDrift(sourceRevision) {
  if (!sourceRevision) return false;
  const differsFromOriginMain = Boolean(
    sourceRevision.head_commit
    && sourceRevision.origin_main_commit
    && sourceRevision.head_commit !== sourceRevision.origin_main_commit
  );
  return differsFromOriginMain || sourceRevision.dirty_worktree === true;
}

function isUnsupportedRpcError(message) {
  if (!message) return false;
  return /unknown command|unsupported|not implemented|invalid command/i.test(String(message));
}

function formatWorkerProbeError(error) {
  if (error === 'Worker not found') return 'worker-not-found';
  return error || 'worker-command-failed';
}

function detailsMatchRequest(details, requestId) {
  if (details === undefined || details === null) return false;
  if (typeof details === 'string') {
    if (details.includes(requestId)) return true;
    try {
      const parsed = JSON.parse(details);
      return detailsMatchRequest(parsed, requestId);
    } catch {
      return false;
    }
  }
  if (Array.isArray(details)) {
    return details.some((entry) => detailsMatchRequest(entry, requestId));
  }
  if (typeof details === 'object') {
    if (details.request_id === requestId || details.requestId === requestId) return true;
    return Object.values(details).some((value) => detailsMatchRequest(value, requestId));
  }
  return false;
}

function sanitizeBranchName(rawBranch) {
  if (typeof rawBranch !== 'string') return '';
  const trimmed = rawBranch.trim();
  if (!trimmed || !BRANCH_RE.test(trimmed)) return '';
  return trimmed;
}

function parseGitHubRepoFromRemoteUrl(remoteUrl) {
  const trimmed = String(remoteUrl || '').trim();
  if (!trimmed) return '';

  try {
    const parsed = new URL(trimmed);
    const host = (parsed.hostname || '').toLowerCase();
    if (!host.endsWith('github.com')) return '';
    const parts = parsed.pathname.replace(/^\/+|\/+$/g, '').split('/');
    if (parts.length < 2) return '';
    return `${parts[0]}/${parts[1].replace(/\.git$/i, '')}`;
  } catch {
    const sshMatch = trimmed.match(/^git@[^:]+:([^/]+)\/([^/.]+)(?:\.git)?$/i);
    if (sshMatch) return `${sshMatch[1]}/${sshMatch[2]}`;
    return '';
  }
}

function getProjectGitHubRepoPath(cwd = process.cwd()) {
  try {
    const remoteUrl = execFileSync('git', ['remote', 'get-url', 'origin'], {
      encoding: 'utf8',
      cwd,
      stdio: ['ignore', 'pipe', 'ignore'],
    }).trim();
    return parseGitHubRepoFromRemoteUrl(remoteUrl);
  } catch {
    return '';
  }
}

function normalizePrUrl(rawPrUrl, cwd = process.cwd()) {
  if (typeof rawPrUrl !== 'string') return '';
  const trimmed = rawPrUrl.trim();
  if (!trimmed) return '';
  if (PR_URL_RE.test(trimmed)) return trimmed;

  const normalizedMatch = extractPrNumber(trimmed);
  if (!normalizedMatch) return trimmed;
  const repoPath = getProjectGitHubRepoPath(cwd);
  if (!repoPath) return trimmed;
  return `https://github.com/${repoPath}/pull/${normalizedMatch}`;
}

function extractPrNumber(rawPr) {
  if (typeof rawPr !== 'string') return '';
  const trimmed = rawPr.trim();
  if (!trimmed) return '';
  const numberMatch = trimmed.match(PR_NUMBER_RE);
  if (numberMatch) return numberMatch[1];
  const refMatch = trimmed.match(PR_REFERENCE_RE);
  if (refMatch) return refMatch[2];
  return '';
}

function looksLikePrInput(rawPr) {
  if (typeof rawPr !== 'string') return false;
  const trimmed = rawPr.trim();
  if (!trimmed) return false;
  return PR_URL_RE.test(trimmed) || Boolean(extractPrNumber(trimmed));
}

function parseWorkerId(rawWorkerId) {
  const parsed = parseInt(rawWorkerId, 10);
  if (!Number.isInteger(parsed) || parsed <= 0) return null;
  return parsed;
}

function branchExists(rawBranch, cwd = process.cwd()) {
  const branch = sanitizeBranchName(rawBranch);
  if (!branch) return false;
  try {
    execFileSync('git', ['show-ref', '--verify', '--quiet', `refs/heads/${branch}`], {
      encoding: 'utf8',
      cwd,
      stdio: ['ignore', 'ignore', 'ignore'],
    });
    return true;
  } catch {
    return false;
  }
}

function getCanonicalWorkerBranch(rawWorkerId) {
  const workerId = parseWorkerId(rawWorkerId);
  if (workerId === null) return '';
  return `agent-${workerId}`;
}

function looksLikeBranchInput(rawBranch, rawWorkerId) {
  const branch = sanitizeBranchName(rawBranch);
  if (!branch) return false;
  const canonical = getCanonicalWorkerBranch(rawWorkerId);
  if (canonical && branch === canonical) return true;
  return WORKER_BRANCH_RE.test(branch) || branch.includes('/') || branch.includes('-task');
}

function readCurrentBranch(cwd = process.cwd()) {
  try {
    return sanitizeBranchName(execFileSync('git', ['branch', '--show-current'], {
      encoding: 'utf8',
      cwd,
      stdio: ['ignore', 'pipe', 'ignore'],
    }));
  } catch {
    return '';
  }
}

function resolveCompleteTaskBranch(requestedBranch, rawWorkerId, projectCwd = process.cwd()) {
  const normalizedRequested = sanitizeBranchName(requestedBranch || '');
  const canonicalWorkerBranch = getCanonicalWorkerBranch(rawWorkerId);
  const currentBranch = readCurrentBranch(projectCwd);

  // Worker ID is authoritative. Always prefer agent-<worker_id> when available.
  if (canonicalWorkerBranch) {
    if (branchExists(canonicalWorkerBranch, projectCwd)) {
      if (normalizedRequested && normalizedRequested !== canonicalWorkerBranch) {
        console.error(`[mac10] complete-task branch mismatch: "${normalizedRequested}" != canonical "${canonicalWorkerBranch}", using "${canonicalWorkerBranch}"`);
      }
      return canonicalWorkerBranch;
    }

    if (normalizedRequested && normalizedRequested !== canonicalWorkerBranch) {
      console.error(`[mac10] complete-task canonical branch missing: "${canonicalWorkerBranch}" not found, using requested "${normalizedRequested}"`);
    }

    if (normalizedRequested && branchExists(normalizedRequested, projectCwd)) {
      console.error(`[mac10] complete-task requested branch "${normalizedRequested}" exists; canonical branch "${canonicalWorkerBranch}" unavailable`);
      return normalizedRequested;
    }
    if (currentBranch && WORKER_BRANCH_RE.test(currentBranch) && currentBranch !== canonicalWorkerBranch) {
      console.error(`[mac10] complete-task current branch mismatch: "${currentBranch}" != missing canonical "${canonicalWorkerBranch}", cannot resolve`);
    }
    return '';
  }

  // Without a valid worker ID, don't trust caller-provided/current branch values.
  if (normalizedRequested) {
    console.error(`[mac10] complete-task branch ignored: "${normalizedRequested}" (unable to resolve canonical worker branch)`);
  }
  if (currentBranch) {
    console.error(`[mac10] complete-task current branch ignored: "${currentBranch}" (unable to resolve canonical worker branch)`);
  }
  return '';
}

function parseCompleteTaskUsage(rawUsage) {
  if (rawUsage === undefined || rawUsage === null || String(rawUsage).trim() === '') return null;

  let parsed;
  try {
    parsed = JSON.parse(rawUsage);
  } catch {
    throw new Error('complete-task usage must be valid JSON');
  }

  if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {
    throw new Error('complete-task usage must be a JSON object');
  }

  return providerOutput.normalizeUsagePayload(parsed, {
    projectDir: process.cwd(),
    provider: process.env.MAC10_AGENT_PROVIDER,
    errorStyle: 'cli',
  });
}

function parseCompleteTaskArgs(optionalArgs, rawWorkerId, projectCwd = process.cwd()) {
  const extras = Array.isArray(optionalArgs) ? optionalArgs : [];
  const positional = [];
  let usageArg = null;

  for (let i = 0; i < extras.length; i++) {
    const arg = extras[i];
    if (arg === '--usage') {
      if (usageArg !== null) throw new Error('complete-task usage can only be provided once');
      if (i + 1 >= extras.length) throw new Error('complete-task --usage flag requires a JSON argument');
      usageArg = extras[i + 1];
      i += 1;
      continue;
    }
    if (typeof arg === 'string' && arg.startsWith('--usage=')) {
      if (usageArg !== null) throw new Error('complete-task usage can only be provided once');
      usageArg = arg.slice('--usage='.length);
      if (!usageArg.trim()) throw new Error('complete-task --usage flag requires a JSON argument');
      continue;
    }
    positional.push(arg);
  }

  const usage = parseCompleteTaskUsage(usageArg);
  const first = typeof positional[0] === 'string' ? positional[0] : '';
  const second = typeof positional[1] === 'string' ? positional[1] : '';

  let rawPrUrl = '';
  let rawBranch = '';
  let resultParts = [];

  const firstTrimmed = first.trim();
  const firstLooksPr = looksLikePrInput(first);
  const firstLooksBranch = looksLikeBranchInput(first, rawWorkerId);
  const secondLooksBranch = looksLikeBranchInput(second, rawWorkerId);

  if (positional.length === 1) {
    if (firstLooksPr) {
      rawPrUrl = firstTrimmed;
    } else if (firstLooksBranch) {
      rawBranch = sanitizeBranchName(first);
    } else {
      resultParts = [first];
    }
  } else if (positional.length > 1 && !firstTrimmed && secondLooksBranch) {
    rawBranch = sanitizeBranchName(second);
    resultParts = positional.slice(2);
  } else if (firstLooksPr) {
    rawPrUrl = firstTrimmed;
    if (secondLooksBranch) {
      rawBranch = sanitizeBranchName(second);
      resultParts = positional.slice(2);
    } else {
      resultParts = positional.slice(1);
    }
  } else if (firstLooksBranch) {
    rawBranch = sanitizeBranchName(first);
    resultParts = positional.slice(1);
  } else {
    resultParts = positional;
  }

  const resolvedBranch = resolveCompleteTaskBranch(rawBranch, rawWorkerId, projectCwd);
  return {
    pr_url: normalizePrUrl(rawPrUrl, projectCwd) || '',
    branch: resolvedBranch || '',
    result: resultParts.join(' ').trim(),
    usage,
  };
}

function parseFailTaskArgs(optionalArgs) {
  const extras = Array.isArray(optionalArgs) ? optionalArgs : [];
  const positional = [];
  let usageArg = null;

  for (let i = 0; i < extras.length; i++) {
    const arg = extras[i];
    if (arg === '--usage') {
      if (usageArg !== null) throw new Error('fail-task usage can only be provided once');
      if (i + 1 >= extras.length) throw new Error('fail-task --usage flag requires a JSON argument');
      usageArg = extras[i + 1];
      i += 1;
      continue;
    }
    if (typeof arg === 'string' && arg.startsWith('--usage=')) {
      if (usageArg !== null) throw new Error('fail-task usage can only be provided once');
      usageArg = arg.slice('--usage='.length);
      if (!usageArg.trim()) throw new Error('fail-task --usage flag requires a JSON argument');
      continue;
    }
    positional.push(arg);
  }

  return {
    error: positional.join(' ').trim(),
    usage: parseCompleteTaskUsage(usageArg),
  };
}

function parseOptionalJsonArg(rawValue) {
  if (rawValue === undefined || rawValue === null) return null;
  const trimmed = String(rawValue).trim();
  if (!trimmed) return null;
  try {
    return JSON.parse(trimmed);
  } catch {
    return trimmed;
  }
}

async function main() {
  const rawArgv = process.argv.slice(2);
  if (rawArgv.length === 0) {
    printUsage();
    process.exit(0);
  }

  // Extract --project <dir> flag
  let projectOverride = null;
  const argv = [];
  for (let i = 0; i < rawArgv.length; i++) {
    if (rawArgv[i] === '--project' && i + 1 < rawArgv.length) {
      projectOverride = rawArgv[++i];
    } else {
      argv.push(rawArgv[i]);
    }
  }

  const cmd = argv[0];

  // System commands that don't go through socket
  if (cmd === 'start') {
    const projectDir = argv[1] || process.cwd();
    const stateDir = path.join(projectDir, '.claude', 'state');
    const pidFile = getPidFilePath(projectDir);

    // Fast-path singleton check by namespace-specific pid file.
    try {
      const existingPid = parseInt(fs.readFileSync(pidFile, 'utf8').trim(), 10);
      if (isPidAlive(existingPid)) {
        console.log(`Coordinator already running for namespace "${NAMESPACE}" (PID ${existingPid}).`);
        process.exit(0);
      }
      // Stale pid file.
      fs.unlinkSync(pidFile);
    } catch {}

    // Clear stale endpoint pointers for this namespace so startup probe doesn't
    // report a false positive from dead socket/port files.
    for (const c of getCandidateTargetsForProject(projectDir)) {
      try {
        await send(c.target, 'ping', {});
      } catch {
        try { if (c.file) fs.unlinkSync(c.file); } catch {}
        if (c.type === 'socket-path-file' || c.type === 'socket-file') {
          try { if (typeof c.target === 'string') fs.unlinkSync(c.target); } catch {}
        }
      }
    }

    const coordinator = path.join(__dirname, '..', 'src', 'index.js');
    console.log(`Starting mac10 coordinator for: ${projectDir}`);
    // Always spawn detached so coordinator survives parent shell exit.
    const { spawn } = require('child_process');
    const child = spawn(process.execPath, [coordinator, projectDir], {
      detached: true,
      stdio: 'ignore',
      env: {
        ...process.env,
        MAC10_NAMESPACE: NAMESPACE,
      },
    });
    child.unref();
    // Wait for coordinator to answer ping on any endpoint
    for (let i = 0; i < 60; i++) {
      const candidates = getCandidateTargetsForProject(projectDir);
      let ready = false;
      for (const c of candidates) {
        try {
          const pong = await send(c.target, 'ping', {});
          if (pong && pong.ok) {
            ready = true;
            break;
          }
        } catch {}
      }
      if (ready) {
        console.log('Coordinator started.');
        process.exit(0);
      }
      await new Promise(r => setTimeout(r, 200));
    }
    console.error('Coordinator failed to start within 12s');
    process.exit(1);
  }

  if (cmd === 'stop') {
    const projectDir = projectOverride
      ? path.resolve(projectOverride)
      : (argv[1] ? path.resolve(argv[1]) : findProjectRoot(process.cwd()));
    const pidFile = getPidFilePath(projectDir);

    let pid = NaN;
    try {
      pid = parseInt(fs.readFileSync(pidFile, 'utf8').trim(), 10);
    } catch {}

    if (isPidAlive(pid)) {
      try { process.kill(pid, 'SIGTERM'); } catch {}
      const deadline = Date.now() + 10000;
      while (Date.now() < deadline && isPidAlive(pid)) {
        await new Promise(r => setTimeout(r, 200));
      }
      if (isPidAlive(pid)) {
        try { process.kill(pid, 'SIGKILL'); } catch {}
      }
    }

    try { fs.unlinkSync(pidFile); } catch {}
    cleanupNamespaceEndpoints(projectDir);
    if (isPidAlive(pid)) {
      console.error(`Failed to stop coordinator for namespace "${NAMESPACE}" (PID ${pid})`);
      process.exit(1);
    }
    console.log(`Coordinator stopped for namespace "${NAMESPACE}"${Number.isInteger(pid) ? ` (PID ${pid})` : ''}.`);
    process.exit(0);
  }

  let loopPrompt = null;
  if (cmd === 'loop') {
    if (argv.length < 2) { console.error('Usage: mac10 loop <prompt>'); process.exit(1); }
    loopPrompt = argv.slice(1).join(' ');
    if (!loopPrompt.trim()) {
      console.error('Error: prompt must be a non-empty string');
      process.exit(1);
    }
  }

  const socketPath = projectOverride ? findConnectionTargetForProject(projectOverride) : findConnectionTarget();

  try {
    let result;
    switch (cmd) {
      // USER
      case 'request':
        if (argv.length < 2) { console.error('Usage: mac10 request <description>'); process.exit(1); }
        result = await send(socketPath, 'request', { description: argv.slice(1).join(' ') });
        if (result.ok) console.log(`Request created: ${result.request_id}`);
        else { console.error(result.error); process.exit(1); }
        break;

      case 'fix':
        if (argv.length < 2) { console.error('Usage: mac10 fix <description>'); process.exit(1); }
        result = await send(socketPath, 'fix', { description: argv.slice(1).join(' ') });
        if (result.ok) console.log(`Urgent fix created: ${result.request_id} (task ${result.task_id})`);
        else { console.error(result.error); process.exit(1); }
        break;

      case 'status':
        result = await send(socketPath, 'status', {});
        if (result.ok) printStatus(result);
        else { console.error(result.error); process.exit(1); }
        break;

      case 'health':
      case 'health-check':
        result = await send(socketPath, 'health-check', {});
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;

      case 'clarify':
        if (argv.length < 3) { console.error('Usage: mac10 clarify <request_id> <message>'); process.exit(1); }
        result = await send(socketPath, 'clarify', {
          request_id: argv[1],
          message: argv.slice(2).join(' '),
        });
        if (result.ok) console.log('Clarification sent.');
        else { console.error(result.error); process.exit(1); }
        break;

      case 'log':
        result = await send(socketPath, 'log', { limit: parseInt(argv[1], 10) || 50, actor: argv[2] });
        if (result.ok) {
          for (const entry of result.logs.reverse()) {
            console.log(`[${entry.created_at}] ${entry.actor}: ${entry.action} ${formatDetails(entry.details)}`);
          }
        } else { console.error(result.error); process.exit(1); }
        break;

      case 'history':
      case 'request-history': {
        if (!argv[1]) { console.error('Usage: mac10 history|request-history <request_id> [limit]'); process.exit(1); }
        const requestId = argv[1];
        const limit = parseInt(argv[2], 10) || 500;
        result = await send(socketPath, 'request-history', { request_id: requestId, limit });

        let rows = [];
        if (result.ok) {
          rows = (result.logs || []).reverse();
        } else if (isUnsupportedRpcError(result.error)) {
          // Rolling upgrade compatibility: emulate request-scoped history from legacy log RPC.
          const legacyLimit = Math.max(limit * 5, 2000);
          const legacyResult = await send(socketPath, 'log', { limit: legacyLimit });
          if (!legacyResult.ok) {
            console.error(legacyResult.error || result.error);
            process.exit(1);
          }
          rows = (legacyResult.logs || [])
            .filter((entry) => detailsMatchRequest(entry.details, requestId))
            .slice(0, limit)
            .reverse();
        } else {
          console.error(result.error);
          process.exit(1);
        }

        if (rows.length === 0) {
          const statusRes = await send(socketPath, 'status', {});
          if (statusRes.ok) {
            const req = (statusRes.requests || []).find((r) => r.id === requestId);
            if (req) {
              console.log(`Request: ${req.id}`);
              console.log(`Status:  ${req.status}`);
              if (req.tier) console.log(`Tier:    T${req.tier}`);
              if (req.created_at) console.log(`Created: ${req.created_at}`);
              console.log(`Desc:    ${req.description}`);
              break;
            }
          }
          console.log(`No history found for ${requestId}.`);
        } else {
          for (const entry of rows) {
            console.log(`[${entry.created_at}] ${entry.actor}: ${entry.action} ${formatDetails(entry.details)}`);
          }
        }
        break;
      }

      // ARCHITECT
      case 'triage':
        if (argv.length < 3) { console.error('Usage: mac10 triage <request_id> <tier> [reasoning]'); process.exit(1); }
        result = await send(socketPath, 'triage', {
          request_id: argv[1],
          tier: parseInt(argv[2], 10),
          reasoning: argv.slice(3).join(' '),
        });
        if (result.ok) console.log('Triage recorded.');
        else { console.error(result.error); process.exit(1); }
        break;

      case 'create-task':
        // JSON input from stdin or arg
        const taskInput = argv[1] === '-' ? fs.readFileSync(0, 'utf8') : argv.slice(1).join(' ');
        const taskArgs = JSON.parse(taskInput);
        result = await send(socketPath, 'create-task', taskArgs);
        if (result.ok) console.log(`Task created: ${result.task_id}`);
        else { console.error(result.error); process.exit(1); }
        break;

      case 'tier1-complete': {
        if (!argv[1]) {
          console.error('Usage: mac10 tier1-complete <request_id> [result|-]');
          process.exit(1);
        }
        const readResultFromStdin = argv.length === 3 && argv[2] === '-';
        const tier1Result = readResultFromStdin ? fs.readFileSync(0, 'utf8') : argv.slice(2).join(' ');
        result = await send(socketPath, 'tier1-complete', {
          request_id: argv[1],
          result: tier1Result,
        });
        if (result.ok) console.log('Tier 1 completed.');
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'ask-clarification':
        result = await send(socketPath, 'ask-clarification', {
          request_id: argv[1],
          question: argv.slice(2).join(' '),
        });
        if (result.ok) console.log('Clarification request sent.');
        else { console.error(result.error); process.exit(1); }
        break;

      // WORKER
      case 'my-task':
        if (!argv[1]) { console.error('Usage: mac10 my-task <worker_id>'); process.exit(1); }
        result = await send(socketPath, 'my-task', { worker_id: argv[1] });
        if (result.ok) {
          if (result.task) {
            console.log(JSON.stringify(result.task, null, 2));
          } else {
            console.log('No task assigned.');
          }
        } else {
          console.error(formatWorkerProbeError(result.error));
          process.exit(1);
        }
        break;

      case 'task-context':
      case 'context-bundle':
        if (!argv[1]) { console.error(`Usage: mac10 ${cmd} <task_id>`); process.exit(1); }
        result = await send(socketPath, 'task-context', { task_id: parseInt(argv[1], 10) });
        if (result.ok) console.log(JSON.stringify(result.bundle, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;

      case 'start-task':
        if (argv.length < 3) { console.error('Usage: mac10 start-task <worker_id> <task_id>'); process.exit(1); }
        result = await send(socketPath, 'start-task', {
          worker_id: argv[1],
          task_id: parseInt(argv[2], 10),
        });
        if (result.ok) console.log('Task started.');
        else { console.error(result.error); process.exit(1); }
        break;

      case 'heartbeat':
        if (!argv[1]) { console.error('Usage: mac10 heartbeat <worker_id>'); process.exit(1); }
        result = await send(socketPath, 'heartbeat', { worker_id: argv[1] });
        if (result.ok) console.log('ok');
        else {
          console.error(formatWorkerProbeError(result.error));
          process.exit(1);
        }
        break;

      case 'reset-worker':
        if (!argv[1]) { console.error('Usage: mac10 reset-worker <worker_id>'); process.exit(1); }
        result = await send(socketPath, 'reset-worker', { worker_id: argv[1] });
        if (result.ok) console.log('ok');
        else { console.error(result.error); process.exit(1); }
        break;

      case 'complete-task':
        if (argv.length < 3) { console.error('Usage: mac10 complete-task <worker_id> <task_id> [pr_url] [branch] [result] [--usage JSON]'); process.exit(1); }
        const parsedWorkerId = parseWorkerId(argv[1]);
        if (parsedWorkerId === null) {
          console.error('Error: worker_id must be a positive integer');
          process.exit(1);
        }
        const parsedTaskId = parseInt(argv[2], 10);
        if (!Number.isInteger(parsedTaskId) || parsedTaskId <= 0) {
          console.error('Error: task_id must be a positive integer');
          process.exit(1);
        }
        const completionProjectCwd = projectOverride ? path.resolve(projectOverride) : process.cwd();
        const completionArgs = parseCompleteTaskArgs(
          argv.slice(3),
          argv[1],
          completionProjectCwd,
        );
        result = await send(socketPath, 'complete-task', {
          worker_id: String(parsedWorkerId),
          task_id: parsedTaskId,
          pr_url: completionArgs.pr_url,
          branch: completionArgs.branch,
          result: completionArgs.result,
          usage: completionArgs.usage,
        });
        if (result.ok) console.log('Task completed.');
        else { console.error(result.error); process.exit(1); }
        break;

      case 'fail-task':
        if (argv.length < 3) { console.error('Usage: mac10 fail-task <worker_id> <task_id> [error] [--usage JSON]'); process.exit(1); }
        const failedWorkerId = parseWorkerId(argv[1]);
        if (failedWorkerId === null) {
          console.error('Error: worker_id must be a positive integer');
          process.exit(1);
        }
        const failedTaskId = parseInt(argv[2], 10);
        if (!Number.isInteger(failedTaskId) || failedTaskId <= 0) {
          console.error('Error: task_id must be a positive integer');
          process.exit(1);
        }
        const failTaskArgs = parseFailTaskArgs(argv.slice(3));
        result = await send(socketPath, 'fail-task', {
          worker_id: String(failedWorkerId),
          task_id: failedTaskId,
          error: failTaskArgs.error,
          usage: failTaskArgs.usage,
        });
        if (result.ok) console.log('Task failure recorded.');
        else { console.error(result.error); process.exit(1); }
        break;

      case 'browser-create-session': {
        if (argv.length < 4) {
          console.error('Usage: mac10 browser-create-session <task_id> <workflow_url> <idempotency_key> [channel]');
          process.exit(1);
        }
        const taskId = parseInt(argv[1], 10);
        if (!Number.isInteger(taskId) || taskId <= 0) {
          console.error('Error: task_id must be a positive integer');
          process.exit(1);
        }
        result = await send(socketPath, 'browser-create-session', {
          task_id: taskId,
          workflow_url: argv[2],
          idempotency_key: argv[3],
          channel: argv[4],
        });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'browser-attach-session': {
        if (argv.length < 4) {
          console.error('Usage: mac10 browser-attach-session <task_id> <session_id> <idempotency_key> [channel]');
          process.exit(1);
        }
        const taskId = parseInt(argv[1], 10);
        if (!Number.isInteger(taskId) || taskId <= 0) {
          console.error('Error: task_id must be a positive integer');
          process.exit(1);
        }
        result = await send(socketPath, 'browser-attach-session', {
          task_id: taskId,
          session_id: argv[2],
          idempotency_key: argv[3],
          channel: argv[4],
        });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'browser-start-job': {
        if (argv.length < 6) {
          console.error('Usage: mac10 browser-start-job <task_id> <session_id> <workflow_url> <idempotency_key> <guidance>');
          process.exit(1);
        }
        const taskId = parseInt(argv[1], 10);
        if (!Number.isInteger(taskId) || taskId <= 0) {
          console.error('Error: task_id must be a positive integer');
          process.exit(1);
        }
        const guidance = argv.slice(5).join(' ').trim();
        if (!guidance) {
          console.error('Error: guidance must be non-empty');
          process.exit(1);
        }
        result = await send(socketPath, 'browser-start-job', {
          task_id: taskId,
          session_id: argv[2],
          workflow_url: argv[3],
          idempotency_key: argv[4],
          guidance,
        });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'browser-callback-chunk': {
        if (argv.length < 8) {
          console.error('Usage: mac10 browser-callback-chunk <task_id> <session_id> <job_id> <callback_token> <idempotency_key> <chunk_index> <chunk>');
          process.exit(1);
        }
        const taskId = parseInt(argv[1], 10);
        if (!Number.isInteger(taskId) || taskId <= 0) {
          console.error('Error: task_id must be a positive integer');
          process.exit(1);
        }
        const chunkIndex = parseInt(argv[6], 10);
        if (!Number.isInteger(chunkIndex) || chunkIndex < 0) {
          console.error('Error: chunk_index must be a non-negative integer');
          process.exit(1);
        }
        const chunk = argv.slice(7).join(' ');
        if (!chunk) {
          console.error('Error: chunk must be non-empty');
          process.exit(1);
        }
        result = await send(socketPath, 'browser-callback-chunk', {
          task_id: taskId,
          session_id: argv[2],
          job_id: argv[3],
          callback_token: argv[4],
          idempotency_key: argv[5],
          chunk_index: chunkIndex,
          chunk,
        });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'browser-complete-job': {
        if (argv.length < 6) {
          console.error('Usage: mac10 browser-complete-job <task_id> <session_id> <job_id> <callback_token> <idempotency_key> [result_json_or_text]');
          process.exit(1);
        }
        const taskId = parseInt(argv[1], 10);
        if (!Number.isInteger(taskId) || taskId <= 0) {
          console.error('Error: task_id must be a positive integer');
          process.exit(1);
        }
        const rawResult = argv.slice(6).join(' ');
        result = await send(socketPath, 'browser-complete-job', {
          task_id: taskId,
          session_id: argv[2],
          job_id: argv[3],
          callback_token: argv[4],
          idempotency_key: argv[5],
          result: parseOptionalJsonArg(rawResult),
        });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'browser-fail-job': {
        if (argv.length < 7) {
          console.error('Usage: mac10 browser-fail-job <task_id> <session_id> <job_id> <callback_token> <idempotency_key> <error>');
          process.exit(1);
        }
        const taskId = parseInt(argv[1], 10);
        if (!Number.isInteger(taskId) || taskId <= 0) {
          console.error('Error: task_id must be a positive integer');
          process.exit(1);
        }
        const errorMessage = argv.slice(6).join(' ').trim();
        if (!errorMessage) {
          console.error('Error: error must be non-empty');
          process.exit(1);
        }
        result = await send(socketPath, 'browser-fail-job', {
          task_id: taskId,
          session_id: argv[2],
          job_id: argv[3],
          callback_token: argv[4],
          idempotency_key: argv[5],
          error: errorMessage,
        });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'browser-job-status': {
        if (argv.length < 4) {
          console.error('Usage: mac10 browser-job-status <task_id> <session_id> <job_id>');
          process.exit(1);
        }
        const taskId = parseInt(argv[1], 10);
        if (!Number.isInteger(taskId) || taskId <= 0) {
          console.error('Error: task_id must be a positive integer');
          process.exit(1);
        }
        result = await send(socketPath, 'browser-job-status', {
          task_id: taskId,
          session_id: argv[2],
          job_id: argv[3],
        });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'distill':
        if (argv.length < 4) { console.error('Usage: mac10 distill <worker_id> <domain> <content>'); process.exit(1); }
        result = await send(socketPath, 'distill', {
          worker_id: argv[1],
          domain: argv[2],
          content: argv.slice(3).join(' '),
        });
        if (result.ok) console.log('Knowledge distilled.');
        else { console.error(result.error); process.exit(1); }
        break;

      case 'inbox': {
        if (!argv[1]) {
          console.error('Usage: mac10 inbox <recipient> [--block] [--peek] [--timeout=ms] [--type=message_type] [--request-id=request_id] (canonical recipient: allocator; alias: master-3)');
          process.exit(1);
        }
        const recipient = normalizeInboxRecipient(argv[1]);
        const options = argv.slice(2);
        let block = false;
        let peek = false;
        let timeout = 300000;
        let type;
        let requestId;

        for (let i = 0; i < options.length; i += 1) {
          const option = options[i];
          if (option === '--block') {
            block = true;
            continue;
          }
          if (option === '--peek') {
            peek = true;
            continue;
          }
          if (option === '--timeout') {
            const timeoutValue = options[i + 1];
            if (!timeoutValue) {
              console.error('Error: --timeout flag requires a value in milliseconds');
              process.exit(1);
            }
            const parsedTimeout = parseInt(timeoutValue, 10);
            if (!Number.isFinite(parsedTimeout) || parsedTimeout <= 0) {
              console.error('Error: --timeout must be a positive integer in milliseconds');
              process.exit(1);
            }
            timeout = parsedTimeout;
            i += 1;
            continue;
          }
          if (option.startsWith('--timeout=')) {
            const parsedTimeout = parseInt(option.split('=')[1], 10);
            if (!Number.isFinite(parsedTimeout) || parsedTimeout <= 0) {
              console.error('Error: --timeout must be a positive integer in milliseconds');
              process.exit(1);
            }
            timeout = parsedTimeout;
            continue;
          }
          if (option === '--type') {
            const typeValue = options[i + 1];
            if (!typeValue) {
              console.error('Error: --type flag requires a message type value');
              process.exit(1);
            }
            type = typeValue;
            i += 1;
            continue;
          }
          if (option.startsWith('--type=')) {
            const typeValue = option.slice('--type='.length);
            if (!typeValue) {
              console.error('Error: --type flag requires a message type value');
              process.exit(1);
            }
            type = typeValue;
            continue;
          }
          if (option === '--request-id') {
            const requestIdValue = options[i + 1];
            if (!requestIdValue) {
              console.error('Error: --request-id flag requires a request id value');
              process.exit(1);
            }
            requestId = requestIdValue;
            i += 1;
            continue;
          }
          if (option.startsWith('--request-id=')) {
            const requestIdValue = option.slice('--request-id='.length);
            if (!requestIdValue) {
              console.error('Error: --request-id flag requires a request id value');
              process.exit(1);
            }
            requestId = requestIdValue;
            continue;
          }
          console.error('Usage: mac10 inbox <recipient> [--block] [--peek] [--timeout=ms] [--type=message_type] [--request-id=request_id] (canonical recipient: allocator; alias: master-3)');
          process.exit(1);
        }

        if (block) {
          result = await send(socketPath, 'inbox-block', { recipient, timeout, peek, type, request_id: requestId });
        } else {
          result = await send(socketPath, 'inbox', { recipient, peek, type, request_id: requestId });
        }
        if (result.ok) {
          if (result.messages.length === 0) {
            console.log('No messages.');
          } else {
            for (const msg of result.messages) {
              console.log(JSON.stringify(msg));
            }
          }
        } else { console.error(result.error); process.exit(1); }
        break;
      }

      // ALLOCATOR
      case 'ready-tasks':
        result = await send(socketPath, 'ready-tasks', {});
        if (result.ok) {
          if (result.tasks.length === 0) {
            console.log('No ready tasks.');
          } else {
            for (const t of result.tasks) {
              console.log(`  #${t.id} [${t.priority}] ${t.subject} ${t.domain ? `[${t.domain}]` : ''}`);
            }
          }
        } else { console.error(result.error); process.exit(1); }
        break;

      case 'assign-task':
        if (argv.length < 3) { console.error('Usage: mac10 assign-task <task_id> <worker_id>'); process.exit(1); }
        result = await send(socketPath, 'assign-task', {
          task_id: parseInt(argv[1], 10),
          worker_id: parseInt(argv[2], 10),
        });
        if (result.ok) console.log(`Task ${result.task_id} assigned to worker-${result.worker_id}.`);
        else { console.error(result.error); process.exit(1); }
        break;

      case 'claim-worker':
        if (!argv[1]) { console.error('Usage: mac10 claim-worker <worker_id> [claimer]'); process.exit(1); }
        result = await send(socketPath, 'claim-worker', {
          worker_id: parseInt(argv[1], 10),
          claimer: argv[2] || 'architect',
        });
        if (result.ok) {
          if (result.claimed) console.log(`Worker ${argv[1]} claimed.`);
          else console.log(`Worker ${argv[1]} not available (busy or already claimed).`);
        } else { console.error(result.error); process.exit(1); }
        break;

      case 'release-worker':
        if (!argv[1]) { console.error('Usage: mac10 release-worker <worker_id>'); process.exit(1); }
        result = await send(socketPath, 'release-worker', {
          worker_id: parseInt(argv[1], 10),
        });
        if (result.ok) console.log(`Worker ${argv[1]} released.`);
        else { console.error(result.error); process.exit(1); }
        break;

      case 'worker-status':
        result = await send(socketPath, 'worker-status', {});
        if (result.ok) {
          if (result.workers.length === 0) {
            console.log('No workers registered.');
          } else {
            for (const w of result.workers) {
              const task = w.current_task_id ? ` task:${w.current_task_id}` : '';
              const dom = w.domain ? ` [${w.domain}]` : '';
              const claim = w.claimed_by ? ` claimed:${w.claimed_by}` : '';
              console.log(`  worker-${w.id} [${w.status}]${dom}${task}${claim}`);
            }
          }
        } else { console.error(result.error); process.exit(1); }
        break;

      case 'check-completion':
        if (!argv[1]) { console.error('Usage: mac10 check-completion <request_id>'); process.exit(1); }
        result = await send(socketPath, 'check-completion', {
          request_id: argv[1],
        });
        if (result.ok) {
          const statusLabel = completionStatusLabel(result);
          const suffix = statusLabel ? ` — ${statusLabel}` : '';
          console.log(`Request ${result.request_id}: ${result.completed}/${result.total} completed, ${result.failed} failed${suffix}`);
        } else { console.error(result.error); process.exit(1); }
        break;

      case 'check-overlaps':
        result = await send(socketPath, 'check-overlaps', {
          request_id: argv[1],
        });
        if (result.ok) {
          if (result.overlaps.length === 0) {
            console.log('No file overlaps detected.');
          } else {
            console.log(`\n=== File Overlaps for ${result.request_id} ===`);
            for (const o of result.overlaps) {
              const icon = o.severity === 'critical' ? 'CRITICAL' : o.severity === 'high' ? 'HIGH' : 'LOW';
              console.log(`  [${icon}] Task #${o.task_a} ↔ Task #${o.task_b}`);
              console.log(`    ${o.subject_a} ↔ ${o.subject_b}`);
              console.log(`    Shared: ${o.shared_files.join(', ')}`);
            }
            console.log('');
          }
        } else { console.error(result.error); process.exit(1); }
        break;

      case 'replan-dependency': {
        if (argv.length < 3) {
          console.error('Usage: mac10 replan-dependency <from_task_id> <to_task_id> [request_id]');
          process.exit(1);
        }
        const fromTaskId = parseInt(argv[1], 10);
        const toTaskId = parseInt(argv[2], 10);
        if (!Number.isInteger(fromTaskId) || fromTaskId <= 0) {
          console.error('Error: from_task_id must be a positive integer');
          process.exit(1);
        }
        if (!Number.isInteger(toTaskId) || toTaskId <= 0) {
          console.error('Error: to_task_id must be a positive integer');
          process.exit(1);
        }
        result = await send(socketPath, 'replan-dependency', {
          from_task_id: fromTaskId,
          to_task_id: toTaskId,
          request_id: argv[3] || undefined,
        });
        if (result.ok) {
          const scopeSuffix = result.request_id ? ` (request ${result.request_id})` : '';
          console.log(
            `Replanned dependency #${fromTaskId} -> #${toTaskId}${scopeSuffix}: ` +
            `${result.updated_count} task(s) updated, ${result.promoted_count} promoted.`
          );
          if (Array.isArray(result.updated_task_ids) && result.updated_task_ids.length > 0) {
            console.log(`Updated: ${result.updated_task_ids.join(', ')}`);
          }
          if (Array.isArray(result.promoted_task_ids) && result.promoted_task_ids.length > 0) {
            console.log(`Promoted: ${result.promoted_task_ids.join(', ')}`);
          }
        } else {
          console.error(result.error);
          process.exit(1);
        }
        break;
      }

      case 'integrate': {
        if (!argv[1]) { console.error('Usage: mac10 integrate <request_id> [--retry-terminal]'); process.exit(1); }
        const options = argv.slice(2);
        let retryTerminal = false;
        for (const option of options) {
          if (option === '--retry-terminal' || option === '--force-retry') {
            retryTerminal = true;
            continue;
          }
          console.error('Usage: mac10 integrate <request_id> [--retry-terminal]');
          process.exit(1);
        }
        result = await send(socketPath, 'integrate', {
          request_id: argv[1],
          retry_terminal: retryTerminal,
          force_retry: retryTerminal,
        });
        if (result.ok) console.log(`Integration triggered for ${result.request_id}: ${result.merges_queued} merge(s) queued.`);
        else { console.error(result.error); process.exit(1); }
        break;
      }

      // SYSTEM
      case 'register-worker':
        result = await send(socketPath, 'register-worker', {
          worker_id: argv[1],
          worktree_path: argv[2] || '',
          branch: argv[3] || '',
        });
        if (result.ok) console.log(`Worker ${result.worker_id} registered.`);
        else { console.error(result.error); process.exit(1); }
        break;

      case 'repair':
        result = await send(socketPath, 'repair', {});
        if (result.ok) {
          const supersessionBackfill = result.supersession_backfill || {};
          const repairedPairs = Number.isFinite(supersessionBackfill.repaired) ? supersessionBackfill.repaired : 0;
          const inspectedPairs = Number.isFinite(supersessionBackfill.inspected) ? supersessionBackfill.inspected : 0;
          console.log(`Repaired: ${result.reset_workers} workers, ${result.orphaned_tasks} tasks, ${repairedPairs}/${inspectedPairs} superseded request pairs`);
        }
        else { console.error(result.error); process.exit(1); }
        break;

      case 'purge-tasks':
        result = await send(socketPath, 'purge-tasks', {});
        if (result.ok) console.log(`Purged ${result.purged_tasks} tasks, ${result.purged_merges} merge entries`);
        else { console.error(result.error); process.exit(1); }
        break;

      case 'ping':
        result = await send(socketPath, 'ping', {});
        if (result.ok) console.log(`pong (${Date.now() - result.ts}ms)`);
        else { console.error(result.error); process.exit(1); }
        break;

      case 'add-worker':
        result = await send(socketPath, 'add-worker', {});
        if (result.ok) console.log(`Worker ${result.worker_id} created (${result.worktree_path}, branch: ${result.branch})`);
        else { console.error(`Error: ${result.error}`); process.exit(1); }
        break;

      case 'merge-status':
        result = await send(socketPath, 'merge-status', { request_id: argv[1] || undefined });
        if (result.ok) {
          if (result.merges.length === 0) {
            console.log('No merge queue entries.');
          } else {
            console.log('\n=== Merge Queue ===');
            for (const m of result.merges) {
              const age = formatMergeAge(m.created_at, true);
              const err = m.error ? ` error: ${m.error.slice(0, 80)}` : '';
              console.log(`  #${m.id} [${m.status}] ${m.branch || '(no branch)'} ${age}${err}`);
            }
            console.log('');
          }
        } else { console.error(result.error); process.exit(1); }
        break;

      case 'log-change': {
        // mac10 log-change <description> [--domain X] [--file Y] [--fn Z] [--tooltip T] [--status S]
        const changeArgs = { description: '' };
        const descParts = [];
        for (let i = 1; i < argv.length; i++) {
          if (argv[i] === '--domain' && argv[i + 1]) { changeArgs.domain = argv[++i]; }
          else if (argv[i] === '--file' && argv[i + 1]) { changeArgs.file_path = argv[++i]; }
          else if (argv[i] === '--fn' && argv[i + 1]) { changeArgs.function_name = argv[++i]; }
          else if (argv[i] === '--tooltip' && argv[i + 1]) { changeArgs.tooltip = argv[++i]; }
          else if (argv[i] === '--status' && argv[i + 1]) { changeArgs.status = argv[++i]; }
          else { descParts.push(argv[i]); }
        }
        changeArgs.description = descParts.join(' ');
        if (!changeArgs.description) {
          console.error('Usage: mac10 log-change <description> [--domain X] [--file Y] [--fn Z] [--tooltip T]');
          process.exit(1);
        }
        result = await send(socketPath, 'log-change', changeArgs);
        if (result.ok) console.log(`Change logged: #${result.change_id}`);
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'list-changes': {
        const listArgs = {};
        if (argv[1]) listArgs.domain = argv[1];
        result = await send(socketPath, 'list-changes', listArgs);
        if (result.ok) {
          if (result.changes.length === 0) {
            console.log('No changes logged.');
          } else {
            for (const c of result.changes) {
              const toggle = c.enabled ? 'ON' : 'OFF';
              const stat = c.status === 'pending_user_action' ? ' [ACTION]' : '';
              console.log(`  #${c.id} [${toggle}]${stat} ${c.description} ${c.domain ? `[${c.domain}]` : ''}`);
            }
          }
        } else { console.error(result.error); process.exit(1); }
        break;
      }

      // LOOP
      case 'loop':
        result = await send(socketPath, 'loop', { prompt: loopPrompt });
        if (result.ok) console.log(`Loop created: ${result.loop_id}`);
        else { console.error(result.error); process.exit(1); }
        break;

      case 'stop-loop':
        if (!argv[1]) { console.error('Usage: mac10 stop-loop <loop_id>'); process.exit(1); }
        result = await send(socketPath, 'stop-loop', { loop_id: parseInt(argv[1], 10) });
        if (result.ok) console.log(`Loop ${result.loop_id} stopped.`);
        else { console.error(result.error); process.exit(1); }
        break;

      case 'loop-status':
        result = await send(socketPath, 'loop-status', {});
        if (result.ok) {
          if (result.loops.length === 0) {
            console.log('No loops.');
          } else {
            for (const l of result.loops) {
              const cp = l.last_checkpoint ? ` checkpoint: ${l.last_checkpoint.slice(0, 60)}` : '';
              console.log(`  #${l.id} [${l.status}] iter:${l.iteration_count}${cp}`);
            }
          }
        } else { console.error(result.error); process.exit(1); }
        break;

      case 'loop-checkpoint':
        if (argv.length < 3) { console.error('Usage: mac10 loop-checkpoint <loop_id> <summary>'); process.exit(1); }
        result = await send(socketPath, 'loop-checkpoint', {
          loop_id: parseInt(argv[1], 10),
          summary: argv.slice(2).join(' '),
        });
        if (result.ok) console.log(`Checkpoint saved (iteration ${result.iteration}).`);
        else { console.error(result.error); process.exit(1); }
        break;

      case 'loop-heartbeat':
        if (!argv[1]) { console.error('Usage: mac10 loop-heartbeat <loop_id>'); process.exit(1); }
        result = await send(socketPath, 'loop-heartbeat', { loop_id: parseInt(argv[1], 10) });
        if (result.ok) {
          if (result.status === 'stopped' || result.status === 'paused') {
            console.log(`Loop ${result.status}`);
            process.exit(2);
          }
          console.log('ok');
        } else { console.error(result.error); process.exit(1); }
        break;

      case 'set-config':
        if (!argv[1] || !argv[2]) { console.error('Usage: mac10 set-config <key> <value>'); process.exit(1); }
        result = await send(socketPath, 'set-config', { key: argv[1], value: argv[2] });
        if (result.ok) console.log(`set ${result.key}=${result.value}`);
        else { console.error(result.error || 'failed'); process.exit(1); }
        break;

      case 'loop-prompt':
        if (!argv[1]) { console.error('Usage: mac10 loop-prompt <loop_id>'); process.exit(1); }
        result = await send(socketPath, 'loop-prompt', { loop_id: parseInt(argv[1], 10) });
        if (result.ok) {
          console.log(JSON.stringify(result, null, 2));
        } else { console.error(result.error); process.exit(1); }
        break;

      case 'loop-refresh-prompt':
        if (argv.length < 3) { console.error('Usage: mac10 loop-refresh-prompt <loop_id> <prompt>'); process.exit(1); }
        result = await send(socketPath, 'loop-refresh-prompt', {
          loop_id: parseInt(argv[1], 10),
          prompt: argv.slice(2).join(' '),
        });
        if (result.ok) console.log(`Loop ${result.loop_id} prompt refreshed.`);
        else { console.error(result.error); process.exit(1); }
        break;

      case 'loop-set-prompt':
        if (argv.length < 3) { console.error('Usage: mac10 loop-set-prompt <loop_id> <prompt>'); process.exit(1); }
        result = await send(socketPath, 'loop-set-prompt', {
          loop_id: parseInt(argv[1], 10),
          prompt: argv.slice(2).join(' '),
        });
        if (result.ok) console.log(`Loop ${result.loop_id} prompt updated.`);
        else { console.error(result.error); process.exit(1); }
        break;

      case 'loop-request':
        if (argv.length < 3) { console.error('Usage: mac10 loop-request <loop_id> <description>'); process.exit(1); }
        result = await send(socketPath, 'loop-request', {
          loop_id: parseInt(argv[1], 10),
          description: argv.slice(2).join(' '),
        });
        if (result.ok) {
          if (result.deduplicated) {
            console.log(`Deduplicated — existing request: ${result.request_id}`);
          } else {
            console.log(`Loop request created: ${result.request_id}`);
          }
          if (result.superseded_target && result.superseded_target.request_id) {
            const target = result.superseded_target;
            const disposition = target.terminalized ? 'terminalized' : (target.already_terminal ? 'already terminal' : 'unchanged');
            const replacedBy = target.replaced_by ? ` replaced_by=${target.replaced_by}` : '';
            console.log(`Superseded target: ${target.request_id} [${target.status}] ${disposition}${replacedBy}`);
          }
        } else { console.error(result.error); process.exit(1); }
        break;

      case 'loop-requests': {
        if (!argv[1]) { console.error('Usage: mac10 loop-requests <loop_id> [--json]'); process.exit(1); }
        const options = argv.slice(2);
        let jsonMode = false;
        for (const option of options) {
          if (option === '--json') {
            jsonMode = true;
            continue;
          }
          console.error('Usage: mac10 loop-requests <loop_id> [--json]');
          process.exit(1);
        }
        result = normalizeLoopRequestsPayload(
          await send(socketPath, 'loop-requests', { loop_id: parseInt(argv[1], 10) })
        );
        if (jsonMode) {
          console.log(JSON.stringify(result, null, 2));
          if (!result.ok) process.exit(1);
        } else if (result.ok) {
          printLoopRequestsRows(result.requests);
        } else {
          console.error(result.error);
          process.exit(1);
        }
        break;
      }

      case 'memory-snapshots': {
        // Parse optional flags: --context --request-id --task-id --run-id --validation --min-relevance --limit --offset
        const msArgs = {};
        for (let i = 1; i < argv.length; i++) {
          const a = argv[i];
          if (a.startsWith('--context=')) msArgs.project_context_key = a.slice('--context='.length);
          else if (a === '--context' && argv[i + 1]) { msArgs.project_context_key = argv[++i]; }
          else if (a.startsWith('--request-id=')) msArgs.request_id = a.slice('--request-id='.length);
          else if (a === '--request-id' && argv[i + 1]) { msArgs.request_id = argv[++i]; }
          else if (a.startsWith('--task-id=')) msArgs.task_id = parseInt(a.slice('--task-id='.length), 10);
          else if (a === '--task-id' && argv[i + 1]) { msArgs.task_id = parseInt(argv[++i], 10); }
          else if (a.startsWith('--run-id=')) msArgs.run_id = a.slice('--run-id='.length);
          else if (a === '--run-id' && argv[i + 1]) { msArgs.run_id = argv[++i]; }
          else if (a.startsWith('--validation=')) msArgs.validation_status = a.slice('--validation='.length);
          else if (a === '--validation' && argv[i + 1]) { msArgs.validation_status = argv[++i]; }
          else if (a.startsWith('--min-relevance=')) msArgs.min_relevance_score = parseFloat(a.slice('--min-relevance='.length));
          else if (a === '--min-relevance' && argv[i + 1]) { msArgs.min_relevance_score = parseFloat(argv[++i]); }
          else if (a.startsWith('--limit=')) msArgs.limit = parseInt(a.slice('--limit='.length), 10);
          else if (a === '--limit' && argv[i + 1]) { msArgs.limit = parseInt(argv[++i], 10); }
          else if (a.startsWith('--offset=')) msArgs.offset = parseInt(a.slice('--offset='.length), 10);
          else if (a === '--offset' && argv[i + 1]) { msArgs.offset = parseInt(argv[++i], 10); }
        }
        result = await send(socketPath, 'memory-snapshots', msArgs);
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'memory-snapshot': {
        if (!argv[1]) {
          console.error('Usage: mac10 memory-snapshot <id> [--lineage]');
          process.exit(1);
        }
        const snapId = parseInt(argv[1], 10);
        if (!Number.isInteger(snapId) || snapId <= 0) {
          console.error('Error: id must be a positive integer');
          process.exit(1);
        }
        const snapIncludeLineage = argv.includes('--lineage');
        result = await send(socketPath, 'memory-snapshot', { id: snapId, include_lineage: snapIncludeLineage });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'memory-insights': {
        const miArgs = {};
        for (let i = 1; i < argv.length; i++) {
          const a = argv[i];
          if (a.startsWith('--context=')) miArgs.project_context_key = a.slice('--context='.length);
          else if (a === '--context' && argv[i + 1]) { miArgs.project_context_key = argv[++i]; }
          else if (a.startsWith('--snapshot-id=')) miArgs.snapshot_id = parseInt(a.slice('--snapshot-id='.length), 10);
          else if (a === '--snapshot-id' && argv[i + 1]) { miArgs.snapshot_id = parseInt(argv[++i], 10); }
          else if (a.startsWith('--type=')) miArgs.artifact_type = a.slice('--type='.length);
          else if (a === '--type' && argv[i + 1]) { miArgs.artifact_type = argv[++i]; }
          else if (a.startsWith('--request-id=')) miArgs.request_id = a.slice('--request-id='.length);
          else if (a === '--request-id' && argv[i + 1]) { miArgs.request_id = argv[++i]; }
          else if (a.startsWith('--task-id=')) miArgs.task_id = parseInt(a.slice('--task-id='.length), 10);
          else if (a === '--task-id' && argv[i + 1]) { miArgs.task_id = parseInt(argv[++i], 10); }
          else if (a.startsWith('--run-id=')) miArgs.run_id = a.slice('--run-id='.length);
          else if (a === '--run-id' && argv[i + 1]) { miArgs.run_id = argv[++i]; }
          else if (a.startsWith('--validation=')) miArgs.validation_status = a.slice('--validation='.length);
          else if (a === '--validation' && argv[i + 1]) { miArgs.validation_status = argv[++i]; }
          else if (a.startsWith('--min-relevance=')) miArgs.min_relevance_score = parseFloat(a.slice('--min-relevance='.length));
          else if (a === '--min-relevance' && argv[i + 1]) { miArgs.min_relevance_score = parseFloat(argv[++i]); }
          else if (a.startsWith('--limit=')) miArgs.limit = parseInt(a.slice('--limit='.length), 10);
          else if (a === '--limit' && argv[i + 1]) { miArgs.limit = parseInt(argv[++i], 10); }
          else if (a.startsWith('--offset=')) miArgs.offset = parseInt(a.slice('--offset='.length), 10);
          else if (a === '--offset' && argv[i + 1]) { miArgs.offset = parseInt(argv[++i], 10); }
        }
        result = await send(socketPath, 'memory-insights', miArgs);
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'memory-insight': {
        if (!argv[1]) {
          console.error('Usage: mac10 memory-insight <id> [--lineage]');
          process.exit(1);
        }
        const insightId = parseInt(argv[1], 10);
        if (!Number.isInteger(insightId) || insightId <= 0) {
          console.error('Error: id must be a positive integer');
          process.exit(1);
        }
        const insightIncludeLineage = argv.includes('--lineage');
        result = await send(socketPath, 'memory-insight', { id: insightId, include_lineage: insightIncludeLineage });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'memory-lineage': {
        const mlArgs = {};
        for (let i = 1; i < argv.length; i++) {
          const a = argv[i];
          if (a.startsWith('--snapshot-id=')) mlArgs.snapshot_id = parseInt(a.slice('--snapshot-id='.length), 10);
          else if (a === '--snapshot-id' && argv[i + 1]) { mlArgs.snapshot_id = parseInt(argv[++i], 10); }
          else if (a.startsWith('--insight-id=')) mlArgs.insight_artifact_id = parseInt(a.slice('--insight-id='.length), 10);
          else if (a === '--insight-id' && argv[i + 1]) { mlArgs.insight_artifact_id = parseInt(argv[++i], 10); }
          else if (a.startsWith('--request-id=')) mlArgs.request_id = a.slice('--request-id='.length);
          else if (a === '--request-id' && argv[i + 1]) { mlArgs.request_id = argv[++i]; }
          else if (a.startsWith('--task-id=')) mlArgs.task_id = parseInt(a.slice('--task-id='.length), 10);
          else if (a === '--task-id' && argv[i + 1]) { mlArgs.task_id = parseInt(argv[++i], 10); }
          else if (a.startsWith('--run-id=')) mlArgs.run_id = a.slice('--run-id='.length);
          else if (a === '--run-id' && argv[i + 1]) { mlArgs.run_id = argv[++i]; }
          else if (a.startsWith('--lineage-type=')) mlArgs.lineage_type = a.slice('--lineage-type='.length);
          else if (a === '--lineage-type' && argv[i + 1]) { mlArgs.lineage_type = argv[++i]; }
          else if (a.startsWith('--limit=')) mlArgs.limit = parseInt(a.slice('--limit='.length), 10);
          else if (a === '--limit' && argv[i + 1]) { mlArgs.limit = parseInt(argv[++i], 10); }
          else if (a.startsWith('--offset=')) mlArgs.offset = parseInt(a.slice('--offset='.length), 10);
          else if (a === '--offset' && argv[i + 1]) { mlArgs.offset = parseInt(argv[++i], 10); }
        }
        result = await send(socketPath, 'memory-lineage', mlArgs);
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'queue-research': {
        if (!argv[1] || !argv[2]) {
          console.error("Usage: mac10 queue-research <topic> <question> [--mode standard|thinking|deep_research] [--priority urgent|normal|low] [--links '[\"url\"]'] [--context \"...\"]");
          process.exit(1);
        }
        const qrArgs = { topic: argv[1], question: argv[2] };
        for (let i = 3; i < argv.length; i++) {
          const a = argv[i];
          if (a.startsWith('--mode=')) qrArgs.mode = a.slice('--mode='.length);
          else if (a === '--mode' && argv[i + 1]) { qrArgs.mode = argv[++i]; }
          else if (a.startsWith('--priority=')) qrArgs.priority = a.slice('--priority='.length);
          else if (a === '--priority' && argv[i + 1]) { qrArgs.priority = argv[++i]; }
          else if (a.startsWith('--links=')) qrArgs.links = a.slice('--links='.length);
          else if (a === '--links' && argv[i + 1]) { qrArgs.links = argv[++i]; }
          else if (a.startsWith('--context=')) qrArgs.context = a.slice('--context='.length);
          else if (a === '--context' && argv[i + 1]) { qrArgs.context = argv[++i]; }
          else if (a.startsWith('--source-task-id=')) qrArgs.source_task_id = parseInt(a.slice('--source-task-id='.length), 10);
          else if (a === '--source-task-id' && argv[i + 1]) { qrArgs.source_task_id = parseInt(argv[++i], 10); }
          else if (a.startsWith('--source-agent=')) qrArgs.source_agent = a.slice('--source-agent='.length);
          else if (a === '--source-agent' && argv[i + 1]) { qrArgs.source_agent = argv[++i]; }
        }
        result = await send(socketPath, 'queue-research', qrArgs);
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'research-status': {
        const rstsArgs = {};
        for (let i = 1; i < argv.length; i++) {
          const a = argv[i];
          if (a.startsWith('--topic=')) rstsArgs.topic = a.slice('--topic='.length);
          else if (a === '--topic' && argv[i + 1]) { rstsArgs.topic = argv[++i]; }
          else if (a.startsWith('--status=')) rstsArgs.status = a.slice('--status='.length);
          else if (a === '--status' && argv[i + 1]) { rstsArgs.status = argv[++i]; }
          else if (a.startsWith('--limit=')) rstsArgs.limit = parseInt(a.slice('--limit='.length), 10);
          else if (a === '--limit' && argv[i + 1]) { rstsArgs.limit = parseInt(argv[++i], 10); }
        }
        result = await send(socketPath, 'research-status', rstsArgs);
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'research-gaps': {
        result = await send(socketPath, 'research-gaps', {});
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'research-retry-failed': {
        const retryArgs = { topic: null, include_running: false };
        for (let ri = 1; ri < argv.length; ri++) {
          if (argv[ri] === '--topic' && argv[ri + 1]) { retryArgs.topic = argv[++ri]; }
          else if (argv[ri] === '--include-running') { retryArgs.include_running = true; }
        }
        result = await send(socketPath, 'research-retry-failed', retryArgs);
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'research-next': {
        result = await send(socketPath, 'research-next', {});
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'research-requeue-stale': {
        const rrsArgs = {};
        if (argv[1]) rrsArgs.max_age_minutes = parseInt(argv[1], 10);
        result = await send(socketPath, 'research-requeue-stale', rrsArgs);
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'research-start': {
        if (!argv[1]) {
          console.error('Usage: mac10 research-start <id>');
          process.exit(1);
        }
        const rsStartId = parseInt(argv[1], 10);
        result = await send(socketPath, 'research-start', { id: rsStartId });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'research-complete': {
        if (!argv[1]) {
          console.error('Usage: mac10 research-complete <id> <note_path>');
          process.exit(1);
        }
        const rcId = parseInt(argv[1], 10);
        const rcNotePath = argv[2] || null;
        result = await send(socketPath, 'research-complete', { intent_id: rcId, note_path: rcNotePath });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'research-fail': {
        if (!argv[1]) {
          console.error('Usage: mac10 research-fail <id> [error]');
          process.exit(1);
        }
        const rfId = parseInt(argv[1], 10);
        const rfError = argv[2] || null;
        result = await send(socketPath, 'research-fail', { intent_id: rfId, error: rfError });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      // TASK SANDBOX LIFECYCLE
      case 'task-sandbox-create': {
        if (!argv[1]) {
          console.error('Usage: mac10 task-sandbox-create <task_id> [backend]');
          process.exit(1);
        }
        result = await send(socketPath, 'task-sandbox-create', {
          task_id: parseInt(argv[1], 10),
          backend: argv[2] || undefined,
        });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'task-sandbox-status': {
        result = await send(socketPath, 'task-sandbox-status', {
          task_id: argv[1] ? parseInt(argv[1], 10) : undefined,
        });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'task-sandbox-ready':
      case 'task-sandbox-start':
      case 'task-sandbox-clean': {
        if (!argv[1]) {
          console.error(`Usage: mac10 ${cmd} <sandbox_id>`);
          process.exit(1);
        }
        result = await send(socketPath, cmd, { id: parseInt(argv[1], 10) });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'task-sandbox-stop': {
        if (!argv[1]) {
          console.error('Usage: mac10 task-sandbox-stop <sandbox_id> [error]');
          process.exit(1);
        }
        result = await send(socketPath, 'task-sandbox-stop', {
          id: parseInt(argv[1], 10),
          error: argv.slice(2).join(' ') || undefined,
        });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'task-sandbox-fail': {
        if (argv.length < 3) {
          console.error('Usage: mac10 task-sandbox-fail <sandbox_id> <error>');
          process.exit(1);
        }
        result = await send(socketPath, 'task-sandbox-fail', {
          id: parseInt(argv[1], 10),
          error: argv.slice(2).join(' '),
        });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'task-sandbox-cleanup': {
        const cleanupArgs = {
          max_age_minutes: argv[1] ? parseInt(argv[1], 10) : undefined,
          dry_run: argv.includes('--dry-run'),
        };
        result = await send(socketPath, 'task-sandbox-cleanup', cleanupArgs);
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      // SANDBOX
      case 'sandbox-status':
        result = await send(socketPath, 'sandbox-status', {});
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;

      case 'sandbox-build':
        console.log('Building sandbox Docker image (this may take a few minutes)...');
        result = await send(socketPath, 'sandbox-build', {});
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;

      case 'sandbox-cleanup':
        result = await send(socketPath, 'sandbox-cleanup', {});
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;

      case 'sandbox-toggle':
        result = await send(socketPath, 'sandbox-toggle', {});
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;

      // MICROVM (msb)
      case 'msb-status':
        result = await send(socketPath, 'msb-status', {});
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;

      case 'msb-setup':
        console.log('Setting up microsandbox (starting server, pulling image)...');
        result = await send(socketPath, 'msb-setup', {});
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;

      case 'msb-cleanup':
        result = await send(socketPath, 'msb-cleanup', {});
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;

      // KNOWLEDGE LAYER
      case 'knowledge-status':
        result = await send(socketPath, 'knowledge-status', {});
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;

      case 'knowledge-increment': {
        const kiArgs = { domain: null, worker_patch: false };
        for (let ki = 1; ki < argv.length; ki++) {
          if (argv[ki] === '--domain' && argv[ki + 1]) { kiArgs.domain = argv[++ki]; }
          else if (argv[ki] === '--worker-patch') { kiArgs.worker_patch = true; }
        }
        result = await send(socketPath, 'knowledge-increment', kiArgs);
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      case 'knowledge-update-index-timestamp':
        result = await send(socketPath, 'knowledge-update-index-timestamp', {});
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;

      case 'fill-knowledge':
        result = await send(socketPath, 'fill-knowledge', {});
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;

      case 'analyze-domain': {
        if (!argv[1]) { console.error('Usage: mac10 analyze-domain <domain>'); process.exit(1); }
        result = await send(socketPath, 'analyze-domain', { domain: argv[1] });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }
      case 'domain-analysis': {
        if (!argv[1]) { console.error('Usage: mac10 domain-analysis <id>'); process.exit(1); }
        result = await send(socketPath, 'domain-analysis', { id: Number(argv[1]) });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }
      case 'domain-analyses': {
        const daArgs = {};
        for (let di = 1; di < argv.length; di++) {
          if (argv[di] === '--domain' && argv[di + 1]) daArgs.domain = argv[++di];
          else if (argv[di] === '--status' && argv[di + 1]) daArgs.status = argv[++di];
          else if (argv[di] === '--limit' && argv[di + 1]) daArgs.limit = Number(argv[++di]);
        }
        result = await send(socketPath, 'domain-analyses', daArgs);
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }
      case 'approve-domain': {
        if (!argv[1]) { console.error('Usage: mac10 approve-domain <id> [feedback]'); process.exit(1); }
        result = await send(socketPath, 'approve-domain', { id: Number(argv[1]), feedback: argv.slice(2).join(' ') || null });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }
      case 'reject-domain': {
        if (!argv[1]) { console.error('Usage: mac10 reject-domain <id> [feedback]'); process.exit(1); }
        result = await send(socketPath, 'reject-domain', { id: Number(argv[1]), feedback: argv.slice(2).join(' ') || null });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }
      case 'submit-domain-draft': {
        if (!argv[1]) { console.error('Usage: mac10 submit-domain-draft <id> <review_sheet> [draft_payload] [analyzed_files]'); process.exit(1); }
        result = await send(socketPath, 'submit-domain-draft', { id: Number(argv[1]), review_sheet: argv[2] || '', draft_payload: argv[3] || '', analyzed_files: argv[4] || '[]' });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }
      case 'create-research-topic': {
        if (!argv[1] || !argv[2]) { console.error('Usage: mac10 create-research-topic <title> <description> [--category X] [--tags JSON]'); process.exit(1); }
        const crtArgs = { title: argv[1], description: argv[2] };
        for (let ci = 3; ci < argv.length; ci++) {
          if (argv[ci] === '--category' && argv[ci + 1]) crtArgs.category = argv[++ci];
          else if (argv[ci] === '--discovery-source' && argv[ci + 1]) crtArgs.discovery_source = argv[++ci];
          else if (argv[ci] === '--loop-id' && argv[ci + 1]) crtArgs.loop_id = Number(argv[++ci]);
          else if (argv[ci] === '--tags' && argv[ci + 1]) crtArgs.tags = argv[++ci];
        }
        result = await send(socketPath, 'create-research-topic', crtArgs);
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }
      case 'research-topic': {
        if (!argv[1]) { console.error('Usage: mac10 research-topic <id>'); process.exit(1); }
        result = await send(socketPath, 'research-topic', { id: Number(argv[1]) });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }
      case 'research-topics': {
        const rtArgs = {};
        for (let ri = 1; ri < argv.length; ri++) {
          if (argv[ri] === '--status' && argv[ri + 1]) rtArgs.review_status = argv[++ri];
          else if (argv[ri] === '--category' && argv[ri + 1]) rtArgs.category = argv[++ri];
          else if (argv[ri] === '--loop-id' && argv[ri + 1]) rtArgs.loop_id = Number(argv[++ri]);
          else if (argv[ri] === '--limit' && argv[ri + 1]) rtArgs.limit = Number(argv[++ri]);
        }
        result = await send(socketPath, 'research-topics', rtArgs);
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }
      case 'review-research-topic': {
        if (!argv[1] || !argv[2]) { console.error('Usage: mac10 review-research-topic <id> <approved|held|rejected> [notes]'); process.exit(1); }
        result = await send(socketPath, 'review-research-topic', { id: Number(argv[1]), review_status: argv[2], notes: argv.slice(3).join(' ') || null });
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }
      case 'pending-reviews': {
        const prArgs = {};
        for (let pi = 1; pi < argv.length; pi++) {
          if (argv[pi] === '--limit' && argv[pi + 1]) prArgs.limit = Number(argv[++pi]);
        }
        result = await send(socketPath, 'pending-reviews', prArgs);
        if (result.ok) console.log(JSON.stringify(result, null, 2));
        else { console.error(result.error); process.exit(1); }
        break;
      }

      default:
        console.error(`Unknown command: ${cmd}`);
        printUsage();
        process.exit(1);
    }
  } catch (e) {
    console.error(`Error: ${e.message}`);
    process.exit(1);
  }
}

function printUsage() {
  console.log(`
mac10 — Multi-agent coordinator CLI

USER:
  request <description>          Submit a new coding request
  fix <description>              Submit an urgent fix (priority queue)
  status                         Show all requests, tasks, and workers
  clarify <request_id> <msg>     Reply to architect clarification
  log [limit] [actor]            Show activity log
  history <request_id> [limit]   Show request-scoped activity history
  request-history <request_id> [limit]  Alias for history

ARCHITECT:
  triage <request_id> <tier> [reasoning]
  create-task <json>             Create task (JSON from stdin with -)
  tier1-complete <request_id> [result|-]
  ask-clarification <request_id> <question>
  inbox <recipient> [--block] [--peek] [--timeout=ms] [--type=message_type] [--request-id=request_id]
                                canonical recipient: allocator (master-3 alias supported)

ALLOCATOR:
  ready-tasks                    List tasks ready for assignment
  assign-task <task_id> <worker_id>  Assign task to worker (atomic)
  claim-worker <worker_id> [claimer]  Mark worker as claimed for manual use
  release-worker <worker_id>     Release worker claim
  worker-status                  Show all workers
  check-completion <request_id>  Check if all tasks for request are done
  check-overlaps <request_id>   Show file overlaps between tasks
  replan-dependency <from_task_id> <to_task_id> [request_id]
                                Replace a blocked dependency across pending tasks and promote unblocked work
  integrate <request_id> [--retry-terminal]
                                 Trigger worktree merge/integration (optionally retry terminal merge rows)

WORKER:
  my-task <worker_id>            Get current assigned task
  task-context <task_id>         Get coordinator-served task context bundle
  context-bundle <task_id>       Alias for task-context
  start-task <worker_id> <task_id>
  heartbeat <worker_id>
  reset-worker <worker_id>       Reset worker to idle state
  complete-task <worker_id> <task_id> [pr_url] [branch] [result] [--usage JSON]
  fail-task <worker_id> <task_id> [error] [--usage JSON]
  distill <worker_id> <domain> <content>
  browser-create-session <task_id> <workflow_url> <idempotency_key> [channel]
  browser-attach-session <task_id> <session_id> <idempotency_key> [channel]
  browser-start-job <task_id> <session_id> <workflow_url> <idempotency_key> <guidance>
  browser-callback-chunk <task_id> <session_id> <job_id> <callback_token> <idempotency_key> <chunk_index> <chunk>
  browser-complete-job <task_id> <session_id> <job_id> <callback_token> <idempotency_key> [result_json_or_text]
  browser-fail-job <task_id> <session_id> <job_id> <callback_token> <idempotency_key> <error>
  browser-job-status <task_id> <session_id> <job_id>

LOOPS:
  loop <prompt>                  Start a persistent autonomous loop
  stop-loop <loop_id>            Stop a running loop
  loop-status                    Show all loops
  loop-checkpoint <id> <summary> Save checkpoint (increments iteration)
  loop-heartbeat <id>            Heartbeat (exits 2 if stopped)
  set-config <key> <value>        Set coordinator config at runtime (no restart needed)
  loop-prompt <id>               Get loop prompt + checkpoint for sentinel
  loop-refresh-prompt <id> <prompt> Refresh prompt for an active loop
  loop-set-prompt <id> <prompt>  Update existing loop prompt for active/paused loops
  loop-request <id> <desc>       Submit request from loop (dedup + supersession-aware)
  loop-requests <id> [--json]    List all requests for a loop

MEMORY:
  memory-snapshots [--context K] [--request-id R] [--task-id N] [--run-id R] [--validation V] [--min-relevance F] [--limit N] [--offset N]
                                 List project memory snapshots with optional filters
  memory-snapshot <id> [--lineage]
                                 Get a single memory snapshot (optionally with lineage links)
  memory-insights [--context K] [--snapshot-id N] [--type T] [--request-id R] [--task-id N] [--run-id R] [--validation V] [--min-relevance F] [--limit N] [--offset N]
                                 List insight artifacts with optional filters
  memory-insight <id> [--lineage]
                                 Get a single insight artifact (optionally with lineage links)
  memory-lineage [--snapshot-id N] [--insight-id N] [--request-id R] [--task-id N] [--run-id R] [--lineage-type T] [--limit N] [--offset N]
                                 Query lineage links for traceability

CHANGES:
  log-change <desc> [--domain X] [--file Y] [--fn Z] [--tooltip T]
  list-changes [domain]          List all changes (optionally filter by domain)

SANDBOX (Docker):
  task-sandbox-create <task_id> [backend]
                                 Allocate lifecycle state for a disposable task sandbox
  task-sandbox-status [task_id]  List task sandbox lifecycle records
  task-sandbox-ready <id>        Mark task sandbox ready
  task-sandbox-start <id>        Mark task sandbox running
  task-sandbox-stop <id> [err]   Mark task sandbox stopped
  task-sandbox-fail <id> <err>   Mark task sandbox failed
  task-sandbox-clean <id>        Mark task sandbox cleaned
  task-sandbox-cleanup [min] [--dry-run]
                                 Clean stopped/failed task sandboxes older than min
  sandbox-status                 Show Docker availability and containers
  sandbox-build                  Build (or rebuild) the sandbox Docker image
  sandbox-cleanup                Stop all Docker sandbox containers
  sandbox-toggle                 Toggle auto-isolation on/off (affects both Docker and msb)

MICROVM (msb):
  msb-status                     Show microsandbox install/server/sandbox status
  msb-setup                      Start msb server and pull default image
  msb-cleanup                    Stop all msb worker sandboxes

SYSTEM:
  start [project_dir]            Start coordinator
  stop [project_dir]             Stop coordinator
  repair                         Fix stuck state
  purge-tasks                    Remove all failed tasks and their merge queue entries
  add-worker                     Create a new worker worktree (up to max_workers)
  merge-status [request_id]      Show merge queue entries
  health-check                   Show structured coordinator/runtime health
  ping                           Check coordinator health

FLAGS:
  --project <dir>                Use coordinator for specified project dir
`.trim());
}

function printStatus(data) {
  if (data.project_dir) {
    console.log(`\n=== Project: ${data.project_dir} ===`);
  }
  const sourceRevision = normalizeSourceRevision(data);
  const dirtyLabel = sourceRevision.dirty_worktree === null
    ? 'unknown'
    : (sourceRevision.dirty_worktree ? 'dirty' : 'clean');
  const aheadLabel = sourceRevision.ahead_count === null ? 'unknown' : String(sourceRevision.ahead_count);
  const behindLabel = sourceRevision.behind_count === null ? 'unknown' : String(sourceRevision.behind_count);
  console.log(`  Source Revision: branch:${sourceRevision.current_branch || 'unknown'} head:${summarizeCommit(sourceRevision.head_commit)} origin/main:${summarizeCommit(sourceRevision.origin_main_commit)} ahead:${aheadLabel} behind:${behindLabel} worktree:${dirtyLabel}`);
  if (hasRevisionDrift(sourceRevision)) {
    console.log('  WARNING: Source revision drift detected (head differs from origin/main or worktree is dirty).');
  }

  console.log('\n=== Requests ===');
  if (data.requests.length === 0) {
    console.log('  (none)');
  } else {
    for (const r of data.requests) {
      console.log(`  ${r.id} [${r.status}] ${r.tier ? `T${r.tier}` : '  '} ${formatRequestSummaryDescription(r.description)}`);
    }
  }

  console.log('\n=== Workers ===');
  if (data.workers.length === 0) {
    console.log('  (none registered)');
  } else {
    for (const w of data.workers) {
      const task = w.current_task_id ? ` task:${w.current_task_id}` : '';
      const dom = w.domain ? ` [${w.domain}]` : '';
      const hb = w.last_heartbeat ? ` hb:${w.last_heartbeat}` : '';
      console.log(`  worker-${w.id} [${w.status}]${dom}${task}${hb}`);
    }
  }

  console.log('\n=== Tasks ===');
  const activeTasks = data.tasks.filter(t => t.status !== 'completed');
  if (activeTasks.length === 0) {
    console.log('  (none active)');
  } else {
    for (const t of activeTasks) {
      const worker = t.assigned_to ? ` → worker-${t.assigned_to}` : '';
      console.log(`  #${t.id} [${t.status}] ${t.subject.slice(0, 50)}${worker}`);
    }
  }

  if (data.merges && data.merges.length > 0) {
    console.log('\n=== Merges ===');
    for (const m of data.merges) {
      const age = formatMergeAge(m.created_at);
      const err = m.error ? ` — ${m.error.slice(0, 60)}` : '';
      console.log(`  #${m.id} [${m.status}] ${m.branch || '(no branch)'} (${age})${err}`);
    }
  }

  console.log('');
}

main().catch(e => { console.error(e); process.exit(1); });
