#!/usr/bin/env bash
MAC10_BIN="/mnt/c/Users/Owner/Desktop/setup-agents-codex10/coordinator/bin/mac10"
# Derive project root from MAC10_BIN — worktree-safe (avoids resolving relative to CWD)
PROJECT_ROOT="$(cd "$(dirname "$MAC10_BIN")/../.." && pwd)"
if [ ! -f "$MAC10_BIN" ]; then
  echo "ERROR: mac10 CLI not found at $MAC10_BIN" >&2
  echo "  Has the setup-agents repo moved? Re-run setup.sh to fix." >&2
  exit 1
fi
export MAC10_NAMESPACE="codex10-setup-agents"
exec node "$MAC10_BIN" --project "$PROJECT_ROOT" "$@"
