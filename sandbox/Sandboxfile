name: ${MAC10_SANDBOX_NAME:-mac10-workers}

sandboxes:
  worker-1:
    image: node:20
    cpus: 2
    memory: 2048
    volumes:
      - ../.worktrees/wt-1:/workspace
    network:
      scope: any
    secrets:
      - ANTHROPIC_API_KEY
      - OPENAI_API_KEY
      - MAC10_NAMESPACE
      - MAC10_CLI_HOST
      - MAC10_CLI_PORT
    scripts:
      start: MAC10_SANDBOX=1 MAC10_CLI_HOST=127.0.0.1 MAC10_CLI_PORT=31195 bash /workspace/.claude/scripts/worker-sentinel.sh 1 /workspace

