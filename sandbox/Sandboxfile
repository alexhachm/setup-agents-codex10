name: mac10-workers

sandboxes:
  worker-1:
    image: node:20
    cpus: 2
    memory: 2048
    volumes:
      - ./.worktrees/wt-1:/workspace
    network:
      allow:
        - api.anthropic.com
        - github.com
        - api.openai.com
        - registry.npmjs.org
    secrets:
      - ANTHROPIC_API_KEY
      - OPENAI_API_KEY
    scripts:
      start: bash /workspace/.claude/scripts/worker-sentinel.sh 1 /workspace

