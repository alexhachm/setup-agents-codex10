FROM node:20-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl tmux ca-certificates \
    xvfb \
    libx11-xcb1 libxcomposite1 libxcursor1 libxdamage1 libxext6 \
    libxfixes3 libxi6 libxrandr2 libxrender1 libxss1 libxtst6 \
    libnss3 libnspr4 libasound2 libatk1.0-0 libatk-bridge2.0-0 \
    libcups2 libdbus-1-3 libdrm2 libgbm1 libgtk-3-0 libpango-1.0-0 \
    libpangocairo-1.0-0 libxshmfence1 fonts-liberation \
  && rm -rf /var/lib/apt/lists/*

# Install Playwright MCP server and Chromium browser
RUN npm install -g @playwright/mcp@latest && npx playwright install chromium

WORKDIR /workspace

# Worker sentinel script is mounted via volume or copied at build time
# COPY scripts/worker-sentinel.sh /usr/local/bin/

ENTRYPOINT ["bash"]
